# Copiar este archivo como ".env" y completar los valores reales (nunca subir ".env" a git).

SECRET_KEY=cambia-esta-clave-por-una-generada-para-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Si no se define (dejar comentada), se usa SQLite localmente. En producción usar PostgreSQL:
# DATABASE_URL=postgres://usuario:password@host:5432/nombre_bd

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SMTP (Fase 2 — motor de notificaciones)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
